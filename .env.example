APP_NAME=LvlUp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-1ae17810-lvlup.d.aivencloud.com
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
MYSQL_ATTR_SSL_CA=

SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
RUN_MIGRATIONS=true

CACHE_STORE=failover
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90
REDIS_QUEUE_CONNECTION=default

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://127.0.0.1:8000

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
RESUME_AI_TIMEOUT=45
RESUME_AI_CONTENT_MODEL=mistral-medium-3.5-128b
RESUME_AI_LAYOUT_MODEL=mistral-small-4-119b-2603
RESUME_AI_LONG_CONTEXT_MODEL=nemotron-3-super-120b-a12b
RESUME_AI_LONG_CONTEXT_THRESHOLD=9000
